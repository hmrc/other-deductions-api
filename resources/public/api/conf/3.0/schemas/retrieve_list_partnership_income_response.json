{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Retrieve List of Partner Income Submissions",
  "type": "object",
  "properties": {
    "CorrelationId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique transaction reference"
    },
    "partnerIncomeSubmissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "partnershipUtr": {
            "type": "string",
            "pattern": "^\\d{10}$",
            "description": "The partnership UTR"
          },
          "partnershipName": {
            "type": "string",
            "maxLength": 105,
            "description": "The name of the partnership"
          }
        },
        "required": ["partnershipUtr", "partnershipName"]
      }
    }
  },
  "required": ["CorrelationId", "partnerIncomeSubmissions"],
  "additionalProperties": false
}
